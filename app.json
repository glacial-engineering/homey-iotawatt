{
  "id": "com.glacialengineering.homey.iotawatt",
  "version": "1.0.1",
  "compatibility": ">=5.0.0",
  "sdk": 3,
  "name": {
    "en": "IoTaWatt"
  },
  "description": {
    "en": "Monitor energy usage from IoTaWatt devices"
  },
  "category": [
    "energy"
  ],
  "permissions": [],
  "author": {
    "name": "Glacial Engineering",
    "email": "github@glacial.engineering"
  },
  "drivers": [
    {
      "id": "energy-device",
      "name": {
        "en": "IoTaWatt Energy Device"
      },
      "class": "sensor",
      "icon": "/assets/icon.svg",
      "capabilities": [
        "measure_power",
        "meter_power"
      ],
      "capabilitiesOptions": {
        "meter_power": {
          "approximated": false
        }
      },
      "energy": {
        "cumulative": true
      },
      "settings": [
        {
          "id": "iotawattUrl",
          "type": "text",
          "label": {
            "en": "IoTaWatt URL"
          },
          "value": "",
          "hint": {
            "en": "Base URL of your IoTaWatt (e.g. http://iotawatt.local)"
          }
        },
        {
          "id": "pollInterval",
          "type": "number",
          "label": {
            "en": "Polling interval (seconds)"
          },
          "value": 30,
          "min": 5,
          "max": 300
        }
      ],
      "pair": [
        {
          "id": "login_credentials",
          "template": "login_credentials",
          "options": {
            "title": {
              "en": "Connect to IoTaWatt"
            },
            "usernameLabel": {
              "en": "IoTaWatt URL"
            },
            "usernamePlaceholder": {
              "en": "http://iotawatt.local"
            },
            "passwordLabel": {
              "en": "Password (leave blank if none)"
            },
            "passwordPlaceholder": {
              "en": "(optional)"
            }
          }
        },
        {
          "id": "list_devices",
          "template": "list_devices",
          "navigation": {
            "next": "add_devices"
          }
        },
        {
          "id": "add_devices",
          "template": "add_devices"
        }
      ]
    }
  ]
}
